{
  "_meta": {
    "version": "V30",
    "description": "Golden expected reply bodies for 8 email types × 2 GRC configs",
    "grc_constraints": [
      "agencies",
      "non_commissionable",
      "esp_verified_domains",
      "dc_emails",
      "dedicated_ip_setup",
      "dmarc_recipient"
    ]
  },
  "cases": {
    "urgent": {
      "desc": "Server outage / critical system failure",
      "high_confidence": {
        "reply_all": true,
        "use_cc": "dc-admin@dc.com",
        "use_cc_source": "thread_participants",
        "reply_body_contains": ["acknowledged", "investigating", "ETA"],
        "reply_body_not_contains": ["uncertain", "usually"],
        "urgency_normalized": "urgent",
        "route": "fast_path"
      },
      "low_confidence": {
        "reply_all": false,
        "reply_body_contains": ["received", "routing"],
        "route": "escalated"
      }
    },
    "support_issue": {
      "desc": "Feature request or bug report",
      "high_confidence": {
        "reply_all": true,
        "use_cc": "product@esp.com",
        "use_cc_source": "original_cc",
        "reply_body_contains": ["thank", "logged", "team"],
        "reply_body_not_contains": ["guarantee", "promise"],
        "urgency_normalized": "medium",
        "route": "full_pipeline"
      }
    },
    "sales_lead": {
      "desc": "Cold lead requesting quote or demo",
      "high_confidence": {
        "reply_all": false,
        "reply_body_contains": ["interested", "available"],
        "reply_body_not_contains": ["guarantee refund"],
        "reply_all_enforced": false,
        "route": "full_pipeline"
      }
    },
    "personal_one2one": {
      "desc": "Direct message to Kleber, personal relationship",
      "high_confidence": {
        "reply_all": false,
        "reply_body_contains": ["Hi", "Kleber"],
        "reply_body_not_contains": ["sent on behalf", "our team"],
        "route": "fast_path"
      }
    },
    "financial": {
      "desc": "Invoice, payment, billing document",
      "high_confidence": {
        "reply_all": false,
        "reply_body_contains": ["received", "processing"],
        "reply_body_not_contains": ["confirm receipt immediately"],
        "route": "full_pipeline"
      }
    },
    "cancellation": {
      "desc": "Subscription or service cancellation request",
      "high_confidence": {
        "reply_all": false,
        "reply_body_contains": ["understand", "confirmed"],
        "reply_body_not_contains": ["sorry to see you"],
        "route": "full_pipeline"
      }
    },
    "meeting": {
      "desc": "Meeting request with availability included",
      "high_confidence": {
        "reply_all": true,
        "use_cc": "assistant@dc.com",
        "use_cc_source": "thread_participants",
        "reply_body_contains": ["📅", "Suggested slots"],
        "reply_all_enforced": true,
        "route": "full_pipeline"
      }
    },
    "partnership": {
      "desc": "Partnership or strategic collaboration inquiry",
      "high_confidence": {
        "reply_all": true,
        "use_cc": "partnerships@esp.com",
        "use_cc_source": "cc_memory",
        "reply_body_contains": ["excited", "alignment"],
        "reply_all_enforced": true,
        "route": "full_pipeline"
      }
    }
  },
  "grc_variants": {
    "agency_email": {
      "sender_domain": "agency-client.com",
      "esp_verified": true,
      "dc_location": "EU",
      "grp_required": true,
      "enforce_reply_all": true,
      "note": "Agency affiliates must always be CC'd on replies"
    },
    "non_commissionable": {
      "sender_domain": "nonprofit.org",
      "esp_verified": true,
      "dc_location": "US",
      "grp_required": false,
      "enforce_reply_all": false,
      "note": "Non-commissionable: dry-run only, no send"
    }
  },
  "verification_checks": {
    "self_verify_passthreshold": 75,
    "placeholder_check_keywords": ["{name}", "{missing}", "{date}"],
    "sign_off_patterns": ["— Kleber", "— Kleber, Zion Tech Group", "abraço"],
    "continuity_name_max_distance_words": 50
  }
}
