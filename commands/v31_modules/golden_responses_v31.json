{
  "_meta": {
    "version": "V31",
    "builds_on": "V30",
    "description": "Golden expected outputs for V31's 5 new modules",
    "new_modules": [
      "thread_context_bank",
      "cron_schedule",
      "real_llm_verify",
      "billing_attachment",
      "persona_routing"
    ]
  },
  "cases": {
    "thread_context_bank": {
      "save_load_roundtrip": {
        "thread_id": "thread-001",
        "context": {"intent": "urgent", "use_cc": "dc@test.com"},
        "expects": {"intent": "urgent", "use_cc": "dc@test.com", "has_ts": true}
      },
      "stale_filtered": {
        "thread_id": "thread-002",
        "max_age_hours": 0,
        "expects": {"entry_count": 0}
      },
      "touch_updates_participants": {
        "thread_id": "thread-001",
        "touch_participant": "vip@test.com",
        "expects": {"last_participant": "vip@test.com"}
      }
    },
    "cron_schedule": {
      "outcome_learner_job": {
        "schedule": "0 2 * * *",
        "workdir": "/workspace",
        "expects": {
          "schedule_match": "0 2 * * *",
          "deliver": "local",
          "skills_include": "outcome_auto_learner"
        }
      },
      "invalid_5field": {
        "expr": "0 2 * *",
        "expects": {"valid": false}
      }
    },
    "real_llm_verify": {
      "clean_reply": {
        "body": "Hi Alice,\n\nGot your message — I'll follow up shortly.\n\n— Kleber, Zion Tech Group",
        "intent": "general",
        "expects": {"overall_present": true, "dimensions_present": true}
      }
    },
    "billing_attachment": {
      "invoice_routing": {
        "filename": "Invoice_May2026.pdf",
        "invoice_id": "INV-2026-089",
        "amount": "$1,200.00",
        "expects": {
          "routing_action": "invoice_thank",
          "has_invoice_id": true,
          "has_amount": true,
          "injection_in_reply": true
        }
      }
    },
    "persona_routing": {
      "urgent_exec_included": {
        "contacts": {
          "alice@dc.com": {"persona": "executive"},
          "bob@legal.com": {"persona": "legal"},
          "carol@esp.com": {"persona": "delivery"}
        },
        "thread_participants": ["alice@dc.com", "bob@legal.com"],
        "intent": "urgent",
        "expects": {
          "alice_in_cc": true,
          "bob_in_cc": true,
          "carol_excluded": true
        }
      }
    }
  }
}
