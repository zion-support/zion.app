{
  "name": "zion-tech-group",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS='--max-old-space-size=4096' npx next build",
    "postbuild": "echo 'postbuild skipped for CI'",
    "start": "npx next start",
    "lint": "eslint . --fix --ignore-pattern \".next/**\" --ignore-pattern \"out/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"build/**\" --max-warnings 0",
    "check:merge-conflicts": "node scripts/automation/check-merge-conflict-markers.cjs",
    "dependabot:validate": "ruby -e \"require 'yaml'; YAML.load_file('.github/dependabot.yml'); puts 'ok: .github/dependabot.yml'\"",
    "codeowners:check": "bash -c 'test -f .github/CODEOWNERS && test -s .github/CODEOWNERS && echo ok: .github/CODEOWNERS'",
    "validate:pm2-singleton-policy": "node automation/validate-pm2-singleton-policy.cjs",
    "validate:pm2-singleton-ecosystem": "node automation/validate-pm2-singleton-ecosystem.cjs",
    "validate:ai-lab-route-contract": "node automation/validate-ai-lab-route-contract.cjs",
    "validate:ai-lab-route-contract:fix": "node automation/validate-ai-lab-route-contract.cjs --fix",
    "ai-lab:hub-links:smoke": "node scripts/automation/ai-lab-hub-links-playwright.cjs",
    "ai-lab:hub-links:compare": "node automation/ai-lab-hub-links-compare.cjs",
    "ai-lab:hub-links:escalate": "node automation/ai-lab-hub-links-escalate.cjs",
    "ai-lab:route-contract:auto-pr": "node automation/ai-lab-route-contract-auto-pr.cjs",
    "pr:comment:ai-lab-route-contract": "node scripts/automation/upsert-pr-ai-lab-contract-comment.cjs",
    "ai-lab:legacy-scaffold-scan": "node automation/ai-lab-legacy-scaffold-scan.cjs",
    "package:scripts:dedup-check": "node scripts/automation/check-package-script-duplicates.cjs",
    "issues:dedupe-create": "node scripts/automation/gh-issue-dedupe-or-create.cjs",
    "issues:close-on-recovery": "node scripts/automation/gh-issue-close-on-recovery.cjs",
    "workflows:issue-dedupe-contract": "node scripts/automation/validate-workflow-issue-dedupe-contract.cjs",
    "workflows:yaml-parse": "ruby scripts/automation/parse-github-workflows-yaml.rb",
    "workflows:contracts:node": "npm run workflows:issue-dedupe-contract && npm run automation:workflow-integrity:audit && npm run pin-actions:strict",
    "workflows:contracts": "npm run workflows:yaml-parse && npm run workflows:contracts:node && npm run workflows:grep-guards",
    "workflows:grep-guards": "bash scripts/automation/run-workflow-grep-guards.sh",
    "workflows:grep-guards:push-token": "bash scripts/automation/run-workflow-grep-guards.sh --push-token",
    "workflows:grep-guards:policy-fast": "bash scripts/automation/run-workflow-grep-guards.sh --policy-fast",
    "workflows:grep-guards:pin": "bash scripts/automation/run-workflow-grep-guards.sh --pin",
    "workflows:grep-guards:permissions": "bash scripts/automation/run-workflow-grep-guards.sh --permissions",
    "workflows:grep-guards:push": "bash scripts/automation/run-workflow-grep-guards.sh --push",
    "workflows:grep-guards:setup-node-policy": "bash scripts/automation/run-workflow-grep-guards.sh --setup-node-policy",
    "workflows:grep-guards:npm-ci-policy": "bash scripts/automation/run-workflow-grep-guards.sh --npm-ci-policy",
    "workflows:grep-guards:runs-on-policy": "bash scripts/automation/run-workflow-grep-guards.sh --runs-on-policy",
    "workflows:grep-guards:dependabot": "npm run dependabot:validate",
    "workflows:grep-guards:codeowners": "npm run codeowners:check",
    "workflows:grep-guards:merge-conflicts": "npm run check:merge-conflicts",
    "workflows:grep-guards:package-dedup": "npm run package:scripts:dedup-check",
    "workflows:grep-guards:parse": "npm run workflows:yaml-parse",
    "workflows:push-helpers:bash-syntax": "bash -n scripts/automation/commit-and-push-main.sh && bash -n scripts/automation/push-main-with-retry.sh",
    "workflows:validate:light": "npm run workflows:yaml-parse && npm run workflows:grep-guards && npm run workflows:push-helpers:bash-syntax && npm run dependabot:validate && npm run codeowners:check && npm run check:merge-conflicts && npm run package:scripts:dedup-check",
    "workflows:contracts:weekly": "npm run workflows:validate:light && npm run workflows:contracts:node",
    "automation:fingerprint-digest": "node automation/generate-automation-fingerprint-incident-digest.cjs",
    "automation:fingerprint-digest:freshness": "node automation/check-fingerprint-digest-freshness.cjs",
    "issues:dedupe:cooldown": "bash scripts/automation/gh-issue-cooldown.sh",
    "incidents:severity:orchestrate": "node automation/ai-incident-severity-orchestrator.cjs",
    "automation:incident-suppression:registry": "node automation/generate-incident-suppression-registry.cjs",
    "automation:local:pm2:start": "pm2 start scripts/automation/pm2-local-automation.config.cjs --update-env",
    "automation:local:pm2:restart": "pm2 restart scripts/automation/pm2-local-automation.config.cjs --update-env",
    "automation:local:pm2:stop": "pm2 stop scripts/automation/pm2-local-automation.config.cjs",
    "automation:local:pm2:delete": "pm2 delete scripts/automation/pm2-local-automation.config.cjs",
    "ai-lab:integrity-check": "node automation/ai-ai-lab-integrity-guard.cjs",
    "app:ai-experiences-health": "node scripts/automation/ai-experiences-health.cjs",
    "type-check": "tsc --noEmit",
    "build:check": "npm run type-check && npm run build",
    "test:ci": "npm test",
    "routes:promotions:check": "node scripts/routes-promotions-check.cjs",
    "sitemap:validate": "npx sitemapper https://ziontechgroup.com/sitemap.xml",
    "seo:audit": "node scripts/seo-audit.cjs",
    "deploy:status:generate": "node scripts/deploy-status-generate.cjs",
    "automation:preflight": "node scripts/automation-preflight.cjs",
    "autonomy:growth-signal": "node automation/autonomous-growth-signal.cjs",
    "autonomy:queue-guard": "node automation/autonomous-writer-queue-guard.cjs",
    "smoke:routes:check": "node scripts/smoke-routes-check.cjs",
    "homepage:ai-sync:check": "node scripts/homepage-ai-sync-check.cjs",
    "generate:service-index": "node scripts/generate_service_index.cjs",
    "automation:workflow-integrity:audit": "node automation/github-workflow-integrity-auditor.cjs",
    "pin-actions:strict": "node scripts/automation/validate-pin-actions.cjs",
    "rsc:guard": "echo \"stub: no-op\" && exit 0",
    "pm2:drift-guard:once": "echo \"stub: no-op\" && exit 0"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "framer-motion": "^12.0.0",
    "imap": "^0.8.19",
    "imapflow": "^1.3.3",
    "lucide-react": "^0.469.0",
    "mailparser": "^3.9.8",
    "next": "^15.1.4",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "esbuild-register": "^3.6.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
