# Google Analytics Tracking ID
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# Environment
NODE_ENV=production

# Build Configuration
VITE_APP_TITLE=Zion Tech Group
VITE_APP_DESCRIPTION=Leading provider of AI-powered enterprise solutions, quantum computing, autonomous systems, and digital transformation services.

# ── Automation AI Provider (multi-provider with free fallbacks) ──
# 1. Primary: Local Ollama (free, no key). Run: npm run llm:install
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_ENABLED=false   # Set to skip Ollama

# 2. Groq (free tier, ultra-fast inference) — console.groq.com
GROQ_API_KEY=

# 3. Google Gemini (free tier, 1.5k req/day) — aistudio.google.com/apikey
GEMINI_API_KEY=

# 4. Cloudflare Workers AI (10k Neurons/day free) — dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# 5. Hugging Face Inference (300 req/hr free) — huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=

# 6. Cerebras (1M tokens/day free) — cloud.cerebras.ai
CEREBRAS_API_KEY=

# 7. DeepSeek (5M tokens free) — platform.deepseek.com
DEEPSEEK_API_KEY=

# 8. Mistral AI (free tier) — console.mistral.ai
MISTRAL_API_KEY=

# 9. Together AI (free research models) — together.ai
TOGETHER_API_KEY=

# 10. Fireworks AI (free trial: 10 RPM) — fireworks.ai
FIREWORKS_API_KEY=

# 11. Cohere (1k req/month free trial) — dashboard.cohere.com
COHERE_API_KEY=

# 12. OpenRouter (fallback when others unavailable)
OPENROUTER_API_KEY=
# Optional upgrades: GROQ_MODEL=llama-3.3-70b-versatile, llama-3.3-70b-specdec; GEMINI_MODEL=gemini-2.5-flash-preview-05-20
OPENROUTER_MODEL=openrouter/free

# Gemini Embeddings (1,500 req/day free) — same key as LLM
# GEMINI_EMBED_MODEL=text-embedding-004

# Pollinations.ai (free image gen) — get key at enter.pollinations.ai
# POLLINATIONS_API_KEY=
# POLLINATIONS_MODEL=flux

# Replicate (free FLUX/Imagen) — replicate.com
# REPLICATE_API_TOKEN=
# REPLICATE_MODEL=flux-schnell
# Anthropic Claude (legacy fallback)
ANTHROPIC_API_KEY=
# OpenAI GPT (legacy fallback)
OPENAI_API_KEY=

# ── Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Social Media Automation ────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_URN=
IG_ACCESS_TOKEN=
IG_USER_ID=
TWITTER_ACCESS_TOKEN=

# ── Email Automation ───────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
EMAIL_SERVICE=gmail

# ── AI Chat Widget (client-side) ──────────────────────────
# Netlify /api/chat uses: Ollama → Groq → Gemini → HF → Cerebras → Cloudflare → DeepSeek → Mistral → Together → Cohere → OpenRouter (server-side)
# Client fallback: OpenRouter direct when /api/chat unavailable
# Rule-based fallback for common questions works without any API key
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# ── Tawk.to Chat Widget (free tier) ────────────────────
NEXT_PUBLIC_TAWK_TO_PROPERTY_ID=YOUR_PROPERTY_ID
NEXT_PUBLIC_TAWK_TO_WIDGET_ID=default

# Sponsor URLs (free platforms)
GITHUB_SPONSORS_URL=https://github.com/sponsors/Zion-support
PAYPAL_URL=https://www.paypal.com/donate?hosted_button_id=YOUR_BUTTON_ID
PATREON_URL=https://www.patreon.com/ZionTech
OPEN_COLLECTIVE_URL=https://opencollective.com/ZionTech
