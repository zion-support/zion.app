# Google Analytics Tracking ID
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# Environment
NODE_ENV=production

# Build Configuration
VITE_APP_TITLE=Zion Tech Group
VITE_APP_DESCRIPTION=Leading provider of AI-powered enterprise solutions, quantum computing, autonomous systems, and digital transformation services.

# ── Automation AI Provider (multi-provider with free fallbacks) ──
#
# Order for AUTO mode (used by all agents and /api/llm/chat):
#   OpenAI (paid) → Anthropic (paid) → FreeCloud (Groq→Gemini→HF→Cerebras→Cloudflare→DeepSeek→Mistral→Together→Cohere→OpenRouter) → Ollama (local)
#
# 1. Primary cloud LLMs (set if you want paid, highest quality)
#    Leave empty to skip directly to free tier
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 2. Free cloud tier (order of fallback when cloud is rate-limited/unavailable):
#    Groq (ultra-fast, 10k req/min) — console.groq.com
GROQ_API_KEY=
#    Google Gemini (quality, 1.5k req/day) — aistudio.google.com/apikey
GEMINI_API_KEY=
#    HuggingFace (limited free) — huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=
#    Cerebras (1M tokens/day) — cloud.cerebras.ai
CEREBRAS_API_KEY=
#    Cloudflare Workers AI (10k Neurons/day) — dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
#    DeepSeek (5M tokens free) — platform.deepseek.com
DEEPSEEK_API_KEY=
#    Mistral AI (free tier) — console.mistral.ai
MISTRAL_API_KEY=
#    Together AI (free research models) — together.ai
TOGETHER_API_KEY=
#    Cohere (1k req/month trial) — dashboard.cohere.com
COHERE_API_KEY=
#    OpenRouter (broad fallback aggregator) — openrouter.ai
OPENROUTER_API_KEY=
#
# Optional model overrides per provider:
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.0-flash-lite
# OPENROUTER_MODEL=openrouter/free

# 3. Local LLM fallback (no key needed, but requires Ollama running locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b

# ── Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Social Media Automation ────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_URN=
IG_ACCESS_TOKEN=
IG_USER_ID=
TWITTER_ACCESS_TOKEN=

# ── Email Automation ───────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
EMAIL_SERVICE=gmail

# ── AI Chat Widget (client-side) ──────────────────────────
# Netlify /api/chat uses: Ollama → Groq → Gemini → HF → Cerebras → Cloudflare → DeepSeek → Mistral → Together → Cohere → OpenRouter (server-side)
# Client fallback: OpenRouter direct when /api/chat unavailable
# Rule-based fallback for common questions works without any API key
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
