# Copy to: ~/.openclaw/openclaw.env
# chmod 600 ~/.openclaw/openclaw.env
#
# OpenClaw + OpenRouter (Bearer token). Do not commit real values.
# Get a key: https://openrouter.ai/settings/keys
#
OPENROUTER_API_KEY=

# Optional: default model ref (OpenClaw uses openrouter/... IDs)
# OPENROUTER_MODEL=openrouter/free
