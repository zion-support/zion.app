[
  {
    "name": "zion_email_workflow",
    "description": "Automated email sending for lead nurturing",
    "trigger": {
      "name": "Lead Created",
      "type": "n8n.trigger",
      "config": {
        "source": "ziontechgroup.com",
        "endpoint": "/api/lead"
      }
    },
    "steps": [
      {
        "name": "Send Email",
        "type": "n8n.action",
        "config": {
          "action": "sendgrid",
          "endpoint": "zion_email_api",
          "parameters": {
            "email": "{{lead.email}}",
            "subject": "Welcome to Zion Tech Group!",
            "html_content": "<h1>Hi {{lead.name}},</h1><p>Thank you for signing up!</p>"
          }
        }
      },
      {
        "name": "Log Action",
        "type": "n8n.action",
        "config": {
          "action": "log",
          "message": "Email sent to {{lead.email}} via SendGrid integration"
        }
      }
    ]
  }
]