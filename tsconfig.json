{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "webworker"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmitOnError": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "incremental": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "app/types/**/*.d.ts",
    "app/types/performance.d.ts",
    "next-env.d.ts",
    ".next/dev/types/**/*.ts",
    "dist/types/**/*.ts",
    "dist/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "src",
    "hooks",
    "types",
    "temp-files",
    "corrupted-src-backup",
    "problematic-files-backup",
    "problematic-pages",
    "**/ai-pages-backup/**",
    "**/ai-pages-disabled/**",
    "**/api-backup/**",
    "**/app-disabled-all/**",
    "**/app-disabled/**",
    "**/app-disabled-problematic/**",
    "**/api-disabled/**",
    "**/ai-customer-support-disabled/**",
    "**/ai-workflow-automation-disabled/**",
    "**/pages.disabled/**",
    "**/lib.disabled/**",
    "**/all-pages-backup/**",
    "**/backup*/**",
    "**/*.backup.*",
    "**/*.bak",
    "**/backup/**",
    "**/clean-build/**",
    "**/apps/**",
    "**/components/api/**",
    "**/contracts/**",
    "**/cypress/**",
    "**/data/**",
    "**/lib.disabled/**",
    "**/lib/**",
    "**/netlify/**",
    "**/pages_backup/**",
    "**/page_template.tsx",
    "**/pages_minimal/**",
    "**/recovered-branches/**",
    "**/scripts/**",
    "**/services/**",
    "**/security.config.ts",
    "**/src-corrupted/**",
    "**/src.broken/**",
    "**/temp_conflicts/**",
    "**/utils/**",
    "**/tailwind.config.ts",
    "**/vite.config.ts",
    "**/zion-ai-assistant/**",
    "**/zion-os/**",
    "**/components-disabled/**",
    "**/config-disabled/**",
    "**/constants-disabled/**",
    "**/contexts-disabled/**",
    "**/hooks-disabled/**",
    "**/pages-disabled/**",
    "**/types-disabled/**",
    "**/*-disabled.*",
    "utils/fsdb.ts",
    "**/__tests__/**",
    "**/*-backup.*",
    "**/*-broken*",
    "**/*-fixed.*",
    "**/corrupted-pages/**",
    "**/ecommerce-analytics-pro/**",
    "**/edge-computing/**",
    "**/*-broken2.*",
    "**/*-original.*",
    "ai-pages-disabled",
    "corrupted-pages",
    "working-pages",
    "backup-unused-components",
    "components.disabled",
    "api-backup",
    "app-disabled",
    "app-disabled-all",
    "apps",
    "blog"
  ]
}
